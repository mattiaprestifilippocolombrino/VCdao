# ============================================================================
# VARIABILI D'AMBIENTE — Configurazione dell'agente Veramo
# ============================================================================
# Copia questo file in .env e compila con i tuoi valori:
#   cp .env.example .env
#
# ⚠️  NON committare MAI il file .env su Git!
#     Il file .gitignore lo esclude già automaticamente.
# ============================================================================

# Infura Project ID — necessario per accedere alla rete Ethereum Sepolia.
# Registrati su https://www.infura.io per ottenerne uno gratuito.
INFURA_PROJECT_ID=your_infura_project_id_here

# Chiave segreta per il KMS (Key Management System).
# Deve essere esattamente 64 caratteri esadecimali (32 byte).
# Viene usata da SecretBox per cifrare le chiavi private nel database.
# Per generarne una nuova, puoi usare:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KMS_SECRET_KEY=your_64_char_hex_key_here

# Percorso del database SQLite.
DATABASE_FILE=database.sqlite
