{
  "compilerOptions": {
    "preserveConstEnums": true,
    "strict": true,
    "target": "es2022",
    "module": "commonjs",
    "rootDir": "./",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "downlevelIteration": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["agent/**/*.ts", "scripts/**/*.ts", "types/**/*.ts"]
}